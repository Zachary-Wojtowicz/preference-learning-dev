{
  "domain": "movies",
  "domain_item": "movie",
  "choice_context": "A person is deciding which movie to watch based on its description, genre, cast, and plot summary.",
  "input_path": "datasets/movies_200.csv",
  "embeddings_parquet": "datasets/movies_200_qwen3-32b-fp8_embedded.parquet",
  "template_path": "datasets/movie_prompt.txt",
  "text_column": "plot_summary",
  "display_column": "title",
  "id_column": "movie_id",
  "embedding_column": "embedding",
  "max_options": 200,
  "output_dir": "outputs/movies_200_qwen32b_full",

  "llm": {
    "base_url": "http://localhost:8004/v1,http://localhost:8005/v1,http://localhost:8006/v1",
    "model": "Qwen/Qwen2.5-32B-Instruct",
    "api_key": "dummy"
  },

  "examples": {
    "num_pairs": 200,
    "strata": 5,
    "num_dimensions": 10,
    "num_themes": 50,
    "max_workers": 32
  },

  "directions": {
    "n_score_sample": 100,
    "n_select": 10,
    "max_workers": 8,
    "score_workers": 4
  },

  "judging": {
    "appearances_per_option": 10,
    "max_workers": 16,
    "lr": 0.05,
    "steps": 1500
  }
}
